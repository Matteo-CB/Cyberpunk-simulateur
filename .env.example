# ============================================
# CYBERPUNK TCG SIMULATOR - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- Database (MongoDB Atlas) ---
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cyberpunk-tcg?retryWrites=true&w=majority

# --- NextAuth ---
NEXTAUTH_SECRET=change-me-to-a-secure-random-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# --- Discord OAuth ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Discord Bot (for role sync, rank-up notifications) ---
BOT_DISCORD_TOKEN=
SERVER_DISCORD_ID=
DISCORD_RANKUP_WEBHOOK_URL=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- App URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Socket.IO ---
NEXT_PUBLIC_SOCKET_URL=

# --- Internal API Key (server-to-API auth for Socket.IO game saving) ---
INTERNAL_API_KEY=change-me-to-a-secure-random-string

# --- Node ---
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# --- Deployment (Railway - auto-detected) ---
# RAILWAY_PUBLIC_DOMAIN=
